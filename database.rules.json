{
  "rules": {
    ".read": false,
    ".write": false,
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$notificationId": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['message', 'read', 'timestamp'])"
        }
      }
    },
    "active_jobs": {
      ".read": "auth != null",
      "$collection": {
        "$jobId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['id', 'operator_id', 'timestamp_update']) && newData.child('operator_id').isString()"
        }
      }
    }
  }
}
