{
  "rules": {
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$notificationId": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['message', 'read', 'timestamp'])"
        }
      }
    },
    "locks": {
      ".read": "auth != null",
      "$jobId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['activeUser', 'timestamp'])"
      }
    },
    "active_jobs": {
      ".read": "auth != null",
      "$collection": {
        "$jobId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['id', 'timestamp_update'])"
        }
      }
    }
  }
}
