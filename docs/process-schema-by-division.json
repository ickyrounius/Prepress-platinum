  "tc_cad_complexity_reference": {
    "description": "Referensi penilaian kerumitan diecut AutoCAD untuk skor CAD (TC).",
    "scale": "1_to_5",
    "levels": [
      {
        "level": 1,
        "label": "Sederhana (Basic)",
        "bentuk": [
          "Kotak (box)",
          "Persegi panjang",
          "Lingkaran dasar"
        ],
        "garis": "Sedikit garis potong (cutting) dan garis lipat (creasing).",
        "fitur": [
          "Tanpa lubang interior",
          "Tanpa sudut tajam khusus",
          "Tanpa radius khusus"
        ],
        "contoh": "Kotak kardus standar"
      },
      {
        "level": 2,
        "label": "Menengah (Moderate)",
        "bentuk": [
          "Bentuk gabungan (persegi dengan flap)"
        ],
        "garis": "Mulai menggunakan sudut tumpul (radius/fillet) pada ujung flap.",
        "fitur": [
          "Satu atau dua notch (takikan) untuk penguncian"
        ]
      },
      {
        "level": 3,
        "label": "Kompleks (Complex)",
        "bentuk": [
          "Bentuk diecut khusus (custom contour) dengan kurva"
        ],
        "garis": "Kombinasi banyak garis potong dan lipat dalam satu komponen.",
        "fitur": [
          "Presisi tinggi pada sudut-sudut dalam",
          "Sering terdapat perforasi"
        ]
      },
      {
        "level": 4,
        "label": "Sangat Kompleks (Highly Complex)",
        "bentuk": [
          "Desain pop-up",
          "Diecut bentuk produk",
          "Banyak lubang kecil interior"
        ],
        "garis": "Kurva organik halus (spline) yang kompleks.",
        "fitur": [
          "Jarak antar garis sangat rapat",
          "Membutuhkan toleransi sangat kecil"
        ]
      },
      {
        "level": 5,
        "label": "Sangat Rumit/Teknis (Extreme Complexity)",
        "bentuk": [
          "Detail mikro (perforasi super kecil atau huruf)",
          "Bentuk 3D rumit yang diratakan"
        ],
        "garis": "Menggunakan fitur nesting untuk efisiensi material maksimum.",
        "fitur": [
          "Kiss-cut (potong stiker tanpa memotong kertas dasar)",
          "Optimasi tata letak bahan tingkat lanjut"
        ]
      }
    ]
  },
  "tc_la_loop_approval_reference": {
    "description": "Referensi skala Loop Approval (LA) untuk kompleksitas siklus persetujuan desain.",
    "scale": "1_to_5",
    "levels": [
      {
        "level": 1,
        "label": "Persetujuan Langsung (Direct Approval)",
        "alur": "Satu arah (Desainer -> Klien/Atasan).",
        "kriteria": [
          "Desain sederhana (contoh: social media post harian)",
          "Tidak butuh asistensi teknis",
          "Revisi minor (warna/teks)",
          "Langsung final"
        ]
      },
      {
        "level": 2,
        "label": "Persetujuan Linear (Standard Loop)",
        "alur": "Bertahap (Desainer -> Editor/Art Director -> Klien).",
        "kriteria": [
          "Desain layout standar (brosur, poster)",
          "Pengecekan elemen visual dasar",
          "Maksimal 2 kali putaran revisi sebelum final"
        ]
      },
      {
        "level": 3,
        "label": "Persetujuan Kolaboratif (Cross-Department)",
        "alur": "Lintas departemen (Desainer -> Marketing -> Legal/Produksi -> Klien).",
        "kriteria": [
          "Desain dengan konten sensitif (iklan cetak, packaging)",
          "Butuh validasi data/teks dari tim lain",
          "Pengecekan spesifikasi teknis cetak"
        ]
      },
      {
        "level": 4,
        "label": "Persetujuan Bertingkat (Multi-Stage Validation)",
        "alur": "Prosedural ketat (Konsep -> Mock-up -> Prototype -> Final Approval).",
        "kriteria": [
          "Desain identitas merek (branding) atau layout buku/majalah besar",
          "Melibatkan banyak stakeholder level manajerial",
          "Butuh dummy fisik sebelum disetujui"
        ]
      },
      {
        "level": 5,
        "label": "Persetujuan Strategis & Teknis (High-Stake Loop)",
        "alur": "Iterasi tanpa batas hingga sempurna (Desainer -> Direksi -> Riset Pasar -> Produksi Massal).",
        "kriteria": [
          "Desain produk global atau kampanye skala nasional",
          "Pengujian usability (untuk UI/UX)",
          "Toleransi kesalahan nol",
          "Persetujuan dari level eksekutif tertinggi"
        ]
      }
    ]
  }
}
