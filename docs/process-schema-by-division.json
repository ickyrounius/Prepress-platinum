        "dept": "DG",
        "role_type": "DG|DS",
        "status_dg": "PROSES|PREVIEW|HOLD|DONE|CANCEL",
        "status_qc": "APPROVED|REJECT|HOLD",
        "pic_utama": "string_optional",
        "pic_support": "string_optional",
        "catatan_spv": "string_optional",
        "catatan_dg": "string_optional",
        "tc": {
          "kt": "number",
          "rp": "number",
          "bs": "number",
          "cad": "number",
          "la": "number",
          "dp": "number",
          "total_tc": "number"
        },
        "timestamp_input": "number",
        "operator_uid": "string"
      }
    },
