{
  "meta": {
    "version": "1.0.0",
    "description": "Schema proses per divisi untuk Prepress App (draft review).",
    "note": "Dokumen ini hanya referensi struktur data. Tidak mengubah implementasi kode."
  },
  "common_fields": {
    "timestamp_input": "epoch_milliseconds",
    "operator_uid": "firebase_auth_uid",
    "catatan": "string_optional"
  },
  "tc_terms": {
    "LA": "Loop Approval (indikator revisi approval berulang/terlalu banyak).",
    "DP": "Deadline Pressure (indikator tekanan deadline)."
  },
  "division_schema": {
